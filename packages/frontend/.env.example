# ─── OpenX-S frontend env.example (Stellar-native, PRD-U) ──────────────────

# Backend API base URL — the Express server (packages/api).
NEXT_PUBLIC_API_URL=http://localhost:3001

# Stellar network + RPC (matches api-side STELLAR_NETWORK).
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# ZK circuit assets served from /public/circuits (see docs/runbooks/ZK_DEPLOY.md).
NEXT_PUBLIC_ZK_CIRCUIT_WASM_URL=/circuits/prove_hire.wasm
NEXT_PUBLIC_ZK_CIRCUIT_ZKEY_URL=/circuits/prove_hire_final.zkey

# Cascading feature flags (frontend mirrors of api-side flags).
NEXT_PUBLIC_FEATURE_M2_BUDGET_VAULT=false
NEXT_PUBLIC_FEATURE_M2_VAULT_YIELD=false

# PRD-U (2026-07-08) — UI v2 refresh (Uniswap + Google inspired).
# Set true to render the new 3-element hero, verb-based nav, and Luminous
# Utility token palette. False keeps the legacy 5-layer stack for one-release
# rollback. See docs/prd/PRD-U-ui-refresh-uniswap-google.md.
NEXT_PUBLIC_FEATURE_UI_V2=false
