# ─── OpenX-S env.example — Stellar-native v3.0.0 ────────────────────────────

# ─── Database (chain-agnostic) ──────────────────────────────────────────────
DATABASE_URL=postgresql://openx:changeme@localhost:5432/openx_s
PORT=3001
API_PUBLIC_URL=http://localhost:3001

# ─── Stellar ────────────────────────────────────────────────────────────────
# testnet | mainnet
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Platform Stellar keypair — pays Soroban tx fees for the relayer-side flows
# (seller publish, paid-call-ledger payouts, privacy-pool admin ops).
# Generate with `stellar keys generate platform --no-fund` then fund from friendbot.
STELLAR_PLATFORM_SECRET_KEY=
STELLAR_PLATFORM_ACCOUNT_ID=

# Stellar USDC SAC id — Circle's wrapped USDC SAC contract id. Override only if
# you point at a custom asset.
STELLAR_USDC_SAC_ID=

# Contract ids — filled in by `bash scripts/deploy-soroban.sh all testnet`.
STELLAR_AGENT_REGISTRY_ID=
STELLAR_PAYWALL_ROUTER_ID=
STELLAR_PAID_CALL_LEDGER_ID=

# ─── ZK Privacy Pool (v3.2 — Nethermind's audited external deployment) ─────
# Populated by `bash scripts/deploy-privacy-pool.sh` (idempotent env-writer).
# Source of truth: NethermindEth/stellar-private-payments deployments.json.
# Pool defaults to the native XLM pool; switch to EURC by setting
# STELLAR_PRIVACY_POOL_ID + STELLAR_PRIVACY_POOL_TOKEN_ID to the EURC ids.
STELLAR_PRIVACY_POOL_ID=CDRC5PLTTIIC7KJ4MFEE3NMLQ3YFWDX4GFPVT4ONMIDJC3KGRWLNFC2Z
STELLAR_PRIVACY_POOL_TOKEN_ID=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC
STELLAR_ASP_MEMBERSHIP_ID=CAN4INFN4G3Z265I5DNUBLW3B2NJW2VBLKVWSVMX3MNJNDUEXI7QETAZ
STELLAR_ASP_NON_MEMBERSHIP_ID=CDXYPQEC3VP5C5MYICD3J66TAVPVDVY5WCYB43APXOB2BCZPB6YDNDBW
STELLAR_GROTH16_VERIFIER_ID=CBDFLMVYC7YNMGVYNCSNNAOYBKUWFG4CFSOGY6JM6K77YIECZFWJXHK5
STELLAR_ZK_POOL_LEVELS=10

# Pricing tiers
PRIVATE_TIER_MULTIPLIER=1.5

# ─── Concierge agent onboarding (PRD-1 — mint by prompt) ──────────────────
# Set to "true" to expose POST /v3/concierge/onboard. Keep false in untrusted
# environments — the endpoint is intentionally permissionless behind a rate
# limit + optional Cloudflare Turnstile.
FEATURE_PUBLIC_AGENT_ONBOARD=false
# Per-IP rate limit (sliding 5-min window). Default 3.
OPENX_CONCIERGE_RATE_LIMIT=3
# Audit fingerprint emitted into `service_signed_permit_hash` + audit row.
# Rotate per deploy to scope listings to a service identity.
OPENX_SERVICE_KEY_ID=svc-stellar-dev
# Wallet that owns concierge-minted listings until the operator binds their
# own Stellar address via /settings. Defaults to STELLAR_PLATFORM_ACCOUNT_ID.
OPENX_SERVICE_PUBLIC_WALLET=
# LLM model used by the concierge extractor.
OPENX_CONCIERGE_MODEL=gpt-4o-mini
# Public-facing URLs that show up in concierge response payloads.
PUBLIC_API_URL=http://localhost:3001
PUBLIC_APP_URL=http://localhost:3000
# Optional Cloudflare Turnstile siteverify secret for the onboard endpoint.
CF_TURNSTILE_SECRET_KEY=

# ─── Payment-gate signing (HMAC nonce, rotate in prod) ─────────────────────
PAYMENT_SECRET=dev-only-rotate-me

# ─── Coinflow Stellar SEP-24 fiat onramp ───────────────────────────────────
# Leave the API key blank in dev — the adapter returns a deterministic mock
# session url so the frontend flow works end-to-end against the smoke suite.
COINFLOW_STELLAR_API_KEY=
COINFLOW_STELLAR_BASE_URL=https://api-sandbox.coinflow.cash/api/stellar
COINFLOW_WEBHOOK_SECRET=

# ─── Credit system (PRD-G, chain-agnostic) ─────────────────────────────────
FEATURE_CREDIT_SYSTEM=false
WELCOME_CREDIT_USDC=25
REVENUE_SPLIT_SELLER_BPS=9500
REVENUE_SPLIT_PLATFORM_BPS=500
REVENUE_SPLIT_COMPUTE_BPS=0
CREDIT_TOPUP_PACKS=25,50,100

# ─── LLM (inference) ───────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENX_DEFAULT_MODEL=gpt-4o-mini
OPENX_DISCOVERY_MODEL=gpt-4o-mini
OPENX_DISCOVERY_LLM=on

# ─── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Frontend (NEXT_PUBLIC_*) ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
# ZK circuit artifacts — served from /public/circuits/ or a CDN.
# Fetch from NethermindEth/stellar-private-payments' Releases page during
# deploy (see docs/runbooks/ZK_DEPLOY.md).
NEXT_PUBLIC_ZK_CIRCUIT_WASM_URL=/circuits/policy_tx_2_2.wasm
NEXT_PUBLIC_ZK_CIRCUIT_ZKEY_URL=/circuits/policy_tx_2_2_final.zkey
NEXT_PUBLIC_PRIVACY_POOL_ID=CDRC5PLTTIIC7KJ4MFEE3NMLQ3YFWDX4GFPVT4ONMIDJC3KGRWLNFC2Z
NEXT_PUBLIC_PRIVACY_POOL_TOKEN_ID=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# ─── Observability ─────────────────────────────────────────────────────────
LOG_LEVEL=info
